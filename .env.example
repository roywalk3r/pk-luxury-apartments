DATABASE_URL="mysql://root:secret@localhost:3306/pk_apartments"
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_TRUST_HOST=true
NEXTAUTH_URL=https://your-production-domain.com

# Payment: Paystack (Ghana - Mobile Money & Cards)
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key
PAYSTACK_CALLBACK_BASE_URL=https://your-production-domain.com

# Email: Google SMTP / Gmail app password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail-address@gmail.com
SMTP_PASSWORD=your-google-app-password
SMTP_FROM_EMAIL=your-gmail-address@gmail.com
SMTP_FROM_NAME="PK Luxury Apartments"

# Laravel-style aliases are also supported by the app:
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-gmail-address@gmail.com
MAIL_PASSWORD=your-google-app-password
MAIL_FROM_ADDRESS=your-gmail-address@gmail.com
MAIL_FROM_NAME="PK Luxury Apartments"

# Cron: external scheduler hits /api/cron/rent-reminders
CRON_SECRET=generate-with-openssl-rand-base64-32

# SMS: mNotify
MNOTIFY_API_KEY=your_mnotify_api_key
MNOTIFY_SENDER_ID=PKLUXURY
MNOTIFY_SMS_ENDPOINT=https://api.mnotify.com/api/sms/quick
